# ─── Auth (matches all existing services) ────────────────────────────────
AUTH_TOKEN_SECRET_KEY=SomeRandomSalt
AUTH_TOKEN_ALGORITHM=HS256
AUTH_TOKEN_NAME=accessToken

# ─── MySQL (same cluster as other services) ───────────────────────────────
# Replace {codex} with actual DB name at runtime
SYNC_CODEX_TETHER_SPELL=mysql+pymysql://admin:%23Pulse%23%242024@pulsedb-feb29.cluster-cia2xris1iid.ap-south-1.rds.amazonaws.com:3306/{codex}
ASYNC_CODEX_TETHER_SPELL=mysql+asyncmy://admin:%23Pulse%23%242024@pulsedb-feb29.cluster-cia2xris1iid.ap-south-1.rds.amazonaws.com:3306/{codex}

# ─── Chat DB name ─────────────────────────────────────────────────────────
CHAT_DB_NAME=connecthub_chat

# ─── AWS S3 ───────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=connecthub-chat-media
AWS_S3_URL_EXPIRY=3600

# ─── File upload limits ───────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20

# ─── Redis — only needed if running multiple pods ─────────────────────
ENABLE_REDIS=false
REDIS_URL=redis://testnew.ks3tw6.clustercfg.aps1.cache.amazonaws.com:6379/0
